# Copy to .env for local development:
#   cp .env.example .env
#
# Start Postgres (from repo root):
#   docker compose -f infrastructure/docker/docker-compose.yml --env-file infrastructure/docker/.env up -d
#
# DATABASE_URL must match infrastructure/docker/.env (user, password, db, port).

# Server
PORT=3001
NODE_ENV=development

# Database (matches infrastructure/docker/.env.example defaults)
DATABASE_URL=postgresql://admin:admin123@localhost:5432/healthcare_saas

# Auth — use strong random values in production
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# CORS (Next.js dev server)
FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

STRIPE_SECRET_KEY=sk_test_xxx

STRIPE_WEBHOOK_SECRET=whsec_xxx

STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx

STRIPE_PLATFORM_FEE_PERCENT=10

STRIPE_STARTER_PRICE_ID=price_1TZVc5BkCpFFDhruUqqzuhJd
STRIPE_PRO_PRICE_ID=price_1TZVcdBkCpFFDhruVEV1W5dC

REDIS_HOST=localhost
REDIS_PORT=6379
