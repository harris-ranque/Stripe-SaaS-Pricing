# Copy to .env for local development:
#   cp .env.example .env
#
# Start Postgres (from repo root):
#   docker compose -f infrastructure/docker/docker-compose.yml --env-file infrastructure/docker/.env up -d
#
# DATABASE_URL must match infrastructure/docker/.env (user, password, db, port).

# Server
PORT=3001
NODE_ENV=development

# Database (matches infrastructure/docker/.env.example defaults)
DATABASE_URL=postgresql://admin:admin123@localhost:5432/healthcare_saas

# Auth — use strong random values in production
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# CORS (Next.js dev server)
FRONTEND_URL=http://localhost:3000
