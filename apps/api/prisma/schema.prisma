generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  googleId           String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  password           String?
  role               Role     @default(CUSTOMER)
  hashedRefreshToken String?
  tokenVersion       Int      @default(0)

  organizationId String?
  organization   Organization? @relation("OrganizationMembers", fields: [organizationId], references: [id])

  ownedOrganization Organization? @relation("OrganizationOwner")

  uploadedFiles File[]
}

model Organization {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  logoUrl     String?
  ownerId     String  @unique
  owner       User    @relation("OrganizationOwner", fields: [ownerId], references: [id])
  members     User[]  @relation("OrganizationMembers")

  // ===============================
  // Stripe connect
  // ===============================

  stripeAccountId          String?
  stripeOnboardingComplete Boolean @default(false)

  payments Payment[]
  files    File[]

  // =========================
  // SAAS Billing
  // =========================
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  stripeSubscriptionStatus     String?
  stripeSubscriptionPlan       String?
  subscriptionCurrentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])
  stripePaymentIntentId String       @unique
  amount                Int
  currency              String
  status                String
  platformFee           Int
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([organizationId])
}

model File {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  uploadedById   String
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])
  originalName   String
  mimeType       String
  size           Int
  storageKey     String       @unique
  publicUrl      String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([uploadedById])
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}
