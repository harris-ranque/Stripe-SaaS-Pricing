generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  password           String
  role               Role     @default(CUSTOMER)
  hashedRefreshToken String?
  tokenVersion       Int      @default(0)
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}
