# Copy to .env for local development:
#   cp .env.example .env
#
# API must be running (apps/api) with matching FRONTEND_URL=http://localhost:3000

API_VERSION=1

# Nest API base URL: <globalPrefix>/v<version> — matches setGlobalPrefix('api') + enableVersioning(URI)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v${API_VERSION}

NEXT_PUBLIC_APP_NAME=Healthcare SaaS

NEXT_PUBLIC_WS_URL=http://localhost:3001/ws