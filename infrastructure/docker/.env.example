# Copy to .env and adjust for local development:
#   cp .env.example .env
#
# Values should match DATABASE_URL in apps/api/.env
# (user, password, database name, host port).

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=healthcare_saas
POSTGRES_PORT=5432

REDIS_PORT=6379

# pgAdmin web UI (http://localhost:${PGADMIN_PORT})
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
